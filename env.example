# Environment variables template for the Tax App
# Copy this file to .env.local or .env.production and fill in the actual values
#
# All variables are now read at RUNTIME (not build time), so one Docker
# image works for every environment. Just supply different env files.

# -----------------------------------------------------------------------------
# Docker Compose Variables
# -----------------------------------------------------------------------------
# The port exposed on the host machine when running via Docker
HOST_PORT=3000

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# The base URL of the upstream server (e.g., PesaFlow / eCitizen API)
# Testing: https://kratest.pesaflow.com/api
# Production: https://ecitizen.kra.go.ke/api
API_URL=https://kratest.pesaflow.com/api

# The public URL of this application
# Used for proxying PDF links securely to WhatsApp
APP_URL=https://tax.chatnation.co.ke

# Logging Configuration
# debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# WhatsApp Business API Configuration
# -----------------------------------------------------------------------------
# The Meta Business Suite ID for the phone number sending messages
WHATSAPP_PHONE_NUMBER_ID=123456789012345

# The System User Access Token with messaging permissions
WHATSAPP_ACCESS_TOKEN=EAA...

# The display number shown to users (without the '+' sign)
WHATSAPP_NUMBER=254700000000

# -----------------------------------------------------------------------------
# Analytics
# -----------------------------------------------------------------------------
ANALYTICS_ENDPOINT=https://analytics.example.com/api/events
ANALYTICS_WRITE_KEY=your-write-key

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Set to 'true' to allow desktop browsers (bypasses mobile-only guard)
ALLOW_DESKTOP_TESTING=false

# -----------------------------------------------------------------------------
# Service Visibility Toggles
# -----------------------------------------------------------------------------
# Control which self-serve items appear on the main menu.
# Set to 'false' to hide a service; omit or set to 'true' to show it.
# SERVICE_SALES_INVOICE=true
# SERVICE_CREDIT_NOTE=true
# SERVICE_BUYER_INITIATED_INVOICES=true
# SERVICE_NIL_FILING=true
# SERVICE_MRI=true
# SERVICE_TOT=true
# SERVICE_ITR=true
# SERVICE_PIN_REGISTRATION=true
# SERVICE_ESLIP=true
# SERVICE_NITA=true
# SERVICE_AHL=true
# SERVICE_TCC_APPLICATION=true
# SERVICE_PIN_RETRIEVE=true
# SERVICE_PIN_CHECK=true
# SERVICE_STAFF_CHECK=true
# SERVICE_STATION=true
# SERVICE_IMPORT_CHECK=true
# SERVICE_PAYROLL=true
