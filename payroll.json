    {
      "name": "Employee Management",
      "item": [
        {
          "name": "Validate Employee Details",
          "description": "Query params pin and tax_payer_pin are both the employee KRA PIN. employer_tax_payer_id must be the numeric employer taxpayer ID (see example 21128), not a KRA PIN.",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/payroll/employee/personal-details/validate?pin=A0******09L&gui=107*****6&type=citizen&first_name=George&employer_tax_payer_id=21128&tax_payer_pin=A0******09L",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payroll",
                "employee",
                "personal-details",
                "validate"
              ],
              "query": [
                {
                  "key": "pin",
                  "value": "A0******09L"
                },
                {
                  "key": "gui",
                  "value": "107*****6"
                },
                {
                  "key": "type",
                  "value": "citizen"
                },
                {
                  "key": "first_name",
                  "value": "George"
                },
                {
                  "key": "employer_tax_payer_id",
                  "value": "21128"
                },
                {
                  "key": "tax_payer_pin",
                  "value": "A0******09L"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Add Single Employee",
          "description": "Individual employer flow: employer_type individual; employee.organization_id may be empty string when not applicable.",
