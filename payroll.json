            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employees\": [\n    {\n      \"basic_salary\": \"60000\",\n      \"contract_type\": \"fixed-term\",\n      \"date_of_completion\": \"2026-01-01\",\n      \"date_of_employment\": \"2024-01-01\",\n      \"dob\": \"2001-06-11\",\n      \"email\": \"\",\n      \"employer_tax_payer_id\": \"21128\",\n      \"employment_no\": \"\",\n      \"gender\": \"M\",\n      \"gui\": \"30**********35\",\n      \"housing_allowance\": \"0\",\n      \"items\": [],\n      \"msisdn\": \"25********55\",\n      \"name\": \"TEST USER\",\n      \"no\": \"1\",\n      \"nssf_no\": \"6788778\",\n      \"organization_id\": \"\",\n      \"pin\": \"A0*********L\",\n      \"primary_employee\": \"yes\",\n      \"shif_no\": \"895570\",\n      \"transport_allowance\": \"0\",\n      \"type\": \"citizen\"\n    }\n  ],\n  \"employer_type\": \"individual\",\n  \"employer_tax_payer_id\": 124234\n}",
              "options": {
                "raw": {
